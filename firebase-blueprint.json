{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of Miaonciclopedia",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "User ID" },
        "displayName": { "type": "string", "description": "User's display name" },
        "email": { "type": "string", "format": "email", "description": "User's email" },
        "photoURL": { "type": "string", "format": "uri", "description": "User's profile photo URL" },
        "role": { "type": "string", "enum": ["admin", "user"], "description": "User's role" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["uid", "displayName", "email", "role", "createdAt"]
    },
    "Article": {
      "title": "Article",
      "description": "An encyclopedia article about cats, MicioOS, etc.",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Article title" },
        "slug": { "type": "string", "description": "URL-friendly slug" },
        "content": { "type": "string", "description": "Markdown content of the article" },
        "authorId": { "type": "string", "description": "UID of the author" },
        "authorName": { "type": "string", "description": "Display name of the author" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" },
        "updatedAt": { "type": "string", "format": "date-time", "description": "Last update timestamp" },
        "purrsCount": { "type": "number", "description": "Number of purrs (likes)" },
        "tags": { 
          "type": "array", 
          "items": { "type": "string" },
          "description": "Tags for the article"
        }
      },
      "required": ["title", "slug", "content", "authorId", "authorName", "createdAt", "updatedAt", "purrsCount", "tags"]
    },
    "Purr": {
      "title": "Purr",
      "description": "A like/purr on an article",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "UID of the user who purred" },
        "articleId": { "type": "string", "description": "ID of the article purred" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["userId", "articleId", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles"
    },
    "articles/{articleId}": {
      "schema": { "$ref": "#/entities/Article" },
      "description": "Encyclopedia articles"
    },
    "purrs/{purrId}": {
      "schema": { "$ref": "#/entities/Purr" },
      "description": "Purrs (likes) given to articles"
    }
  }
}
